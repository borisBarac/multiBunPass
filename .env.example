# ── Core ──────────────────────────────────────────────
# Default remote path inside VMs for file deployment.
# MBP_REMOTE_PATH=~/app/

# Path to a custom cloud-init YAML file (skips auto-discovery if set).
# MBP_CLOUD_CONFIG=./my-cloud-init.yaml

# Log verbosity: debug | info | warn | error | silent
# LOG_LEVEL=warn

# Temp directory for cloud-init config files.
# TMPDIR=/tmp

# TCP connect timeout (ms) for OutputWrapper streaming connections.
# MBP_STREAM_CONNECT_TIMEOUT=30000

# ── E2E Tests ─────────────────────────────────────────
# VM name for lifecycle/server tests (auto-generated if unset).
# E2E_VM_NAME=mbp-e2e-test

# Set to "true" to delete VMs after tests complete.
# E2E_CLEANUP=false

# TCP port for OutputWrapper streaming tests.
# E2E_STREAM_PORT=19876
