{
	"name": "multibunpass",
	"version": "0.1.0",
	"description": "Multipass is great, but the friction is real. MultiBunPass makes Multipass effortless — get isolated, Bun-preinstalled Ubuntu VMs in seconds, designed for rapid development sessions and AI workflows.",
	"author": "Boris Barac (https://www.npmjs.com/~boris.barac)",
	"license": "MIT",
	"homepage": "https://github.com/borisBarac/multiBunPass#readme",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/borisBarac/multiBunPass.git"
	},
	"bugs": {
		"url": "https://github.com/borisBarac/multiBunPass/issues"
	},
	"keywords": [
		"multipass",
		"bun",
		"vm",
		"ubuntu",
		"mcp",
		"ai",
		"sandbox"
	],
	"main": "index.ts",
	"module": "index.ts",
	"types": "index.ts",
	"exports": {
		".": "./index.ts"
	},
	"bin": {
		"multibunpass-mcp": "src/mcp/index.ts",
		"mbp": "src/cli/index.ts"
	},
	"files": [
		"index.ts",
		"src/",
		"README.md"
	],
	"type": "module",
	"scripts": {
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"format": "biome format .",
		"format:fix": "biome format --write .",
		"typecheck": "tsc --noEmit",
		"test": "bun test src/",
		"test-e2e": "bun test e2e/ --timeout 60000",
		"test:watch": "bun test --watch src/",
		"cleanup": "bun src/scripts/cleanup-all.ts",
		"e2e:setup": "bun e2e/setup.ts"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.12",
		"@types/bun": "latest",
		"@types/yargs": "^17.0.35"
	},
	"dependencies": {
		"@modelcontextprotocol/server": "^2.0.0-alpha.2",
		"yargs": "^18.0.0",
		"zod": "^4.3.6"
	}
}
